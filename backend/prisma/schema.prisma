// shopEZ - Prisma schema for MongoDB
// https://prisma.io/docs/orm/reference/prisma-schema-reference

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  username  String
  email     String   @unique
  password  String
  usertype  String   // "user" | "admin"
  createdAt DateTime @default(now())

  cart   Cart[]
  orders Order[]

  @@map("User")
}

model Admin {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  banner     String?
  categories String[]

  @@map("Admin")
}

model Product {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  title             String
  description       String
  mainImg           String
  carousel          String[]
  sizes             String[]
  category          String
  gender            String
  price             Float
  discount          Float
  createdAt         DateTime @default(now())

  @@map("Product")
}

model Cart {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  title       String
  description String
  mainImg     String
  size        String
  quantity    Int
  price       Float
  discount    Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Cart")
}

model Order {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  name          String
  email         String
  mobile        String
  address       String
  pincode       String
  title         String
  description   String
  mainImg       String
  size          String
  quantity      Int
  price         Float
  discount      Float
  paymentMethod String
  orderDate     String
  deliveryDate  String?
  orderStatus   String   @default("order placed") // order placed | in-transit | delivered | cancelled
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("Orders")
}
